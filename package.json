{
  "name": "aquagarden-overlay",
  "version": "0.1.2",
  "description": "Desktop overlay widget - minimal 3D aquarium",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "smoke": "electron-vite build && AQUA_SMOKE=1 electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.aquagarden.overlay",
    "productName": "Aquagarden",
    "directories": { "output": "dist" },
    "files": ["out/**/*", "package.json"],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.entertainment",
      "identity": null
    },
    "afterPack": "build/adhoc-sign.cjs",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "publish": [{ "provider": "github", "owner": "outliner-coach", "repo": "aquagarden-for-builder", "releaseType": "release" }]
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@swc/core": "^1.10.0",
    "@types/node": "^22.10.0",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
